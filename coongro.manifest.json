{
  "id": "contacts",
  "version": "0.2.0",
  "apiVersion": "2.0",
  "assets": {
    "styles": [
      "./dist/assets/tailwind.css",
      "./dist/assets/fontawesome/css/all.min.css"
    ]
  },
  "contributes": {
    "menus": [
      {
        "path": "Showcase",
        "order": 1,
        "viewId": "contacts.showcase.open",
        "icon": "assets/icons/contacts.svg",
        "color": "#7DB09F"
      }
    ],
    "views": [
      {
        "id": "contacts.showcase.open",
        "title": "Showcase",
        "component": "./dist/views/showcase/index.js",
        "export": "ShowcaseView"
      }
    ],
    "repositories": [
      {
        "module": "./dist/repositories/contact.repository.js",
        "export": "ContactRepository",
        "prefix": "contacts"
      }
    ]
  }
}
